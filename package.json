{
  "name": "google-docs-cli",
  "version": "1.0.0",
  "description": "A full-featured CLI for manipulating Google Docs",
  "type": "module",
  "bin": {
    "google-docs-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "google-docs",
    "cli",
    "google-docs-cli",
    "documents",
    "google-workspace"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^170.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
